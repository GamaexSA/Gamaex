{
  "name": "gamaex",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@gamaex/database",
    "db:migrate:dev": "turbo run db:migrate:dev --filter=@gamaex/database",
    "db:migrate:deploy": "turbo run db:migrate:deploy --filter=@gamaex/database",
    "db:studio": "turbo run db:studio --filter=@gamaex/database",
    "db:seed": "turbo run db:seed --filter=@gamaex/database"
  },
  "devDependencies": {
    "turbo": "^2.9.6",
    "typescript": "^5.4.5",
    "prettier": "^3.3.0",
    "@types/node": "^20.14.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma"
    ]
  }
}
