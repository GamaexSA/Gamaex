# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gamaex?schema=public"

# ─── Redis (Upstash) ─────────────────────────────────────────────────────────
REDIS_URL="redis://default:PASSWORD@HOST:PORT"

# ─── ExchangeRatesAPI ────────────────────────────────────────────────────────
EXCHANGE_RATES_API_KEY="your_key_here"
EXCHANGE_RATES_API_URL="https://api.exchangeratesapi.io/v1"

# ─── Auth (JWT) ──────────────────────────────────────────────────────────────
JWT_SECRET="change_this_to_a_random_64_char_string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change_this_to_another_random_64_char_string"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT=3001
API_URL="http://localhost:3001"

# ─── WhatsApp (Meta Business) ────────────────────────────────────────────────
META_WHATSAPP_TOKEN="your_token_here"
META_WEBHOOK_VERIFY_TOKEN="your_custom_verify_token"
META_APP_SECRET="your_app_secret_for_hmac_validation"
META_PHONE_NUMBER_ID="your_phone_number_id"

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ─── Admin frontend ──────────────────────────────────────────────────────────
# (same as web or different domain)
NEXT_PUBLIC_ADMIN_API_URL="http://localhost:3001"
